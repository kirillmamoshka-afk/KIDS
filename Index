<!DOCTYPE html>
<html lang="ru" data-theme="light">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Kids Marketplace Concept</title>
  <style>
    :root {
      --bg: #fff8f2;
      --surface: #ffffff;
      --surface-soft: #fef1e8;
      --text: #2d2a26;
      --muted: #8c847c;
      --primary: #ff7a59;
      --primary-soft: #ffe1d7;
      --secondary: #59c3c3;
      --yellow: #ffd166;
      --border: #f0dfd2;
      --shadow: 0 10px 30px rgba(255, 122, 89, 0.12);
      --radius-xl: 24px;
      --radius-lg: 18px;
      --radius-md: 14px;
      --tabbar-h: 78px;
    }

    * {
      box-sizing: border-box;
    }

    html, body {
      margin: 0;
      padding: 0;
      font-family: Arial, sans-serif;
      background: var(--bg);
      color: var(--text);
    }

    body {
      min-height: 100vh;
    }

    .app {
      min-height: 100vh;
      padding-bottom: calc(var(--tabbar-h) + 16px);
    }

    .screen {
      display: none;
      padding: 20px 16px 24px;
      max-width: 480px;
      margin: 0 auto;
    }

    .screen.active {
      display: block;
    }

    .hero {
      background: linear-gradient(135deg, #fff0e8 0%, #fffdf8 100%);
      border: 1px solid var(--border);
      border-radius: var(--radius-xl);
      padding: 20px;
      box-shadow: var(--shadow);
      margin-bottom: 18px;
    }

    .eyebrow {
      display: inline-block;
      padding: 8px 12px;
      border-radius: 999px;
      background: var(--primary-soft);
      color: var(--primary);
      font-size: 12px;
      margin-bottom: 12px;
    }

    h1, h2, h3, p {
      margin: 0;
    }

    h1 {
      font-size: 28px;
      line-height: 1.15;
      margin-bottom: 10px;
    }

    h2 {
      font-size: 20px;
      margin-bottom: 12px;
    }

    p {
      font-size: 15px;
      line-height: 1.5;
      color: var(--muted);
    }

    .search {
      margin-top: 16px;
      background: #fff;
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 14px 16px;
      color: var(--muted);
      font-size: 14px;
    }

    .section {
      margin-bottom: 18px;
    }

    .cards {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
    }

    .card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius-lg);
      padding: 14px;
      min-height: 120px;
      box-shadow: 0 8px 20px rgba(0,0,0,0.03);
    }

    .card .icon {
      width: 42px;
      height: 42px;
      border-radius: 14px;
      display: grid;
      place-items: center;
      margin-bottom: 12px;
      font-size: 20px;
      background: var(--surface-soft);
    }

    .card strong {
      display: block;
      font-size: 15px;
      margin-bottom: 6px;
    }

    .promo {
      background: linear-gradient(135deg, #59c3c3 0%, #7adfdf 100%);
      color: #fff;
      border-radius: var(--radius-xl);
      padding: 18px;
      margin-bottom: 18px;
    }

    .promo p {
      color: rgba(255,255,255,0.88);
      margin-top: 8px;
    }

    .list {
      display: grid;
      gap: 12px;
    }

    .list-item {
      background: #fff;
      border: 1px solid var(--border);
      border-radius: var(--radius-lg);
      padding: 14px;
      display: flex;
      justify-content: space-between;
      gap: 12px;
      align-items: center;
    }

    .price {
      color: var(--primary);
      font-weight: bold;
      white-space: nowrap;
    }

    .tabbar {
      position: fixed;
      left: 12px;
      right: 12px;
      bottom: 12px;
      height: var(--tabbar-h);
      background: rgba(255,255,255,0.95);
      backdrop-filter: blur(16px);
      border: 1px solid rgba(240, 223, 210, 0.9);
      border-radius: 24px;
      display: flex;
      align-items: center;
      justify-content: space-around;
      box-shadow: 0 10px 35px rgba(0,0,0,0.08);
      max-width: 460px;
      margin: 0 auto;
    }

    .tab-btn {
      flex: 1;
      height: 100%;
      border: 0;
      background: transparent;
      color: var(--muted);
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      gap: 4px;
      font-size: 11px;
      cursor: pointer;
    }

    .tab-btn .icon {
      font-size: 21px;
      line-height: 1;
    }

    .tab-btn.active {
      color: var(--primary);
      font-weight: bold;
    }

    .center-note {
      text-align: center;
      padding: 40px 20px;
      background: #fff;
      border: 1px dashed var(--border);
      border-radius: var(--radius-xl);
    }

    @media (max-width: 380px) {
      .cards {
        grid-template-columns: 1fr;
      }

      h1 {
        font-size: 24px;
      }
    }
  </style>
</head>
